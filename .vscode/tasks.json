{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "moduleFolder",
            "type": "pickString",
            "description": "Selecione qual o módulo a configurar/compilar/testar:",
            "options": [
                "sorting",
                "knapsack-problem-0-1"
            ],
            "default": "knapsack-problem-0-1"
        }
    ],
    "tasks": [
        {
            "label": "Conan: Install",
            "type": "shell",
            "command": "venv/Scripts/Activate.ps1; conan profile detect; conan install conan/conanfile.txt --output-folder=${input:moduleFolder}/build --build=missing -c tools.cmake.cmaketoolchain:generator=Ninja",
            "problemMatcher": []
        },
       {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "venv/Scripts/Activate.ps1; cmake -G Ninja -B '${workspaceFolder}/${input:moduleFolder}/build' -S '${workspaceFolder}/${input:moduleFolder}' -DCMAKE_TOOLCHAIN_FILE='${workspaceFolder}/${input:moduleFolder}/build/conan_toolchain.cmake' -DCMAKE_PREFIX_PATH='${workspaceFolder}/${input:moduleFolder}/build;${workspaceFolder}/${input:moduleFolder}/3rdParty/or-tools' -DCMAKE_POLICY_DEFAULT_CMP0091=NEW -DCMAKE_BUILD_TYPE=Release",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },
        {
            "label": "CMake: Build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/${input:moduleFolder}/build"
            ],
            "dependsOn": "CMake: Configure",
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}/${input:moduleFolder}/build"
            }
        },
        {
            "label": "CMake: Test",
            "type": "shell",
            "command": "ctest",
            "args": [
                "--test-dir", "${workspaceFolder}/${input:moduleFolder}/build",
                "--output-on-failure",
                "--build-config", "Release"
            ],
            "dependsOn": "CMake: Build",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/${input:moduleFolder}/build",
                "--target",
                "clean"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        }
    ]
}